# Example values for all supported Gateway API resources in this chart.
# Render with:
#   helm template nuc-native-gateway . -f values.yaml.example

# Override the generated chart name if needed.
nameOverride: ""

# Labels and annotations merged into every rendered resource.
commonLabels:
  platform: gateway-api
commonAnnotations:
  team: edge

# Optional API version overrides. The chart defaults already match these values.
apiVersions:
  backendTLSPolicy: gateway.networking.k8s.io/v1
  gatewayClass: gateway.networking.k8s.io/v1
  gateway: gateway.networking.k8s.io/v1
  grpcRoute: gateway.networking.k8s.io/v1
  httpRoute: gateway.networking.k8s.io/v1
  listenerSet: gateway.networking.k8s.io/v1
  referenceGrant: gateway.networking.k8s.io/v1
  tlsRoute: gateway.networking.k8s.io/v1

# Backend TLS policies attached to Services.
backendTLSPolicies:
  - name: backend-tls-with-ca
    namespace: app-a
    labels:
      component: backend-tls
    annotations:
      note: ca-bundle
    spec:
      targetRefs:
        - group: ""
          kind: Service
          name: payments
          sectionName: https
      validation:
        hostname: payments.internal.example.com
        caCertificateRefs:
          - group: ""
            kind: ConfigMap
            name: payments-ca
        subjectAltNames:
          - type: Hostname
            hostname: payments.internal.example.com
          - type: URI
            uri: spiffe://cluster.local/ns/app-a/sa/payments
      options:
        example.com/min-version: "1.3"
        example.com/cipher-suites: TLS_AES_128_GCM_SHA256
  - name: backend-tls-with-wellknown
    namespace: app-b
    labels:
      component: backend-tls
    annotations:
      note: system-ca
    spec:
      targetRefs:
        - group: ""
          kind: Service
          name: ledger
      validation:
        hostname: ledger.internal.example.com
        wellKnownCACertificates: System
      options:
        example.com/min-version: "1.2"

# Cluster-scoped GatewayClass resources.
gatewayClasses:
  - name: public-gateway-class
    labels:
      component: gateway-class
    annotations:
      note: public
    spec:
      controllerName: example.net/gateway-controller
      description: Public edge gateway class
      parametersRef:
        group: example.net
        kind: GatewayParameters
        name: public-gateway
        namespace: infra-system

# Gateways that expose listeners to routes.
gateways:
  - name: edge-gateway
    namespace: edge-ns
    labels:
      component: gateway
    annotations:
      note: external
    spec:
      gatewayClassName: public-gateway-class
      addresses:
        - type: IPAddress
          value: 192.0.2.10
        - type: Hostname
          value: edge.example.com
      listeners:
        - name: https
          hostname: api.example.com
          port: 443
          protocol: HTTPS
          tls:
            mode: Terminate
            certificateRefs:
              - group: ""
                kind: Secret
                name: edge-cert
            options:
              example.com/min-version: "1.3"
          allowedRoutes:
            namespaces:
              from: Selector
              selector:
                matchLabels:
                  expose: "true"
                matchExpressions:
                  - key: team
                    operator: In
                    values:
                      - core
            kinds:
              - group: gateway.networking.k8s.io
                kind: HTTPRoute
              - group: gateway.networking.k8s.io
                kind: GRPCRoute
      infrastructure:
        labels:
          infra: public
        annotations:
          infra.example.com/class: internet
        parametersRef:
          group: example.net
          kind: GatewayInfra
          name: edge-config
      allowedListeners:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              shared-gateway: "true"
            matchExpressions:
              - key: env
                operator: In
                values:
                  - prod

# GRPCRoute examples with filters, weighted backends, and session persistence.
grpcRoutes:
  - name: inventory-grpc
    namespace: apps
    labels:
      component: grpc-route
    annotations:
      note: grpc
    spec:
      parentRefs:
        - group: gateway.networking.k8s.io
          kind: Gateway
          name: edge-gateway
          namespace: edge-ns
          sectionName: https
          port: 443
      hostnames:
        - grpc.example.com
      rules:
        - name: inventory
          matches:
            - method:
                type: Exact
                service: inventory.v1.InventoryService
                method: GetItem
              headers:
                - type: Exact
                  name: x-version
                  value: v1
          filters:
            - type: RequestHeaderModifier
              requestHeaderModifier:
                add:
                  - name: x-grpc-added
                    value: "true"
                set:
                  - name: x-grpc-set
                    value: stable
                remove:
                  - x-remove-me
            - type: ResponseHeaderModifier
              responseHeaderModifier:
                add:
                  - name: x-grpc-response
                    value: present
                set:
                  - name: x-grpc-release
                    value: canary
                remove:
                  - x-strip-me
            - type: RequestMirror
              requestMirror:
                backendRef:
                  group: ""
                  kind: Service
                  name: inventory-shadow
                  namespace: shadow
                  port: 9090
                fraction:
                  numerator: 1
                  denominator: 10
            - type: ExtensionRef
              extensionRef:
                group: example.net
                kind: GrpcFilter
                name: authz
          backendRefs:
            - group: ""
              kind: Service
              name: inventory-svc
              namespace: apps
              port: 9090
              weight: 90
              filters:
                - type: RequestHeaderModifier
                  requestHeaderModifier:
                    add:
                      - name: x-backend
                        value: inventory
            - group: ""
              kind: Service
              name: inventory-canary
              port: 9090
              weight: 10
          sessionPersistence:
            sessionName: grpc-session
            absoluteTimeout: 1h
            idleTimeout: 5m
            type: Header
      useDefaultGateways: All

# HTTPRoute examples with matches, redirects, rewrites, CORS, retries, and sessions.
httpRoutes:
  - name: api-http
    namespace: apps
    labels:
      component: http-route
    annotations:
      note: http
    spec:
      parentRefs:
        - group: gateway.networking.k8s.io
          kind: Gateway
          name: edge-gateway
          namespace: edge-ns
          sectionName: https
          port: 443
      hostnames:
        - api.example.com
        - "*.example.com"
      rules:
        - name: api-v1
          matches:
            - path:
                type: PathPrefix
                value: /api
              headers:
                - type: Exact
                  name: x-env
                  value: prod
              queryParams:
                - type: Exact
                  name: version
                  value: v1
              method: GET
          filters:
            - type: RequestHeaderModifier
              requestHeaderModifier:
                add:
                  - name: x-added
                    value: request
                set:
                  - name: x-set
                    value: stable
                remove:
                  - x-remove
            - type: ResponseHeaderModifier
              responseHeaderModifier:
                add:
                  - name: x-response-added
                    value: response
                set:
                  - name: x-response-set
                    value: stable
                remove:
                  - x-response-remove
            - type: RequestMirror
              requestMirror:
                backendRef:
                  group: ""
                  kind: Service
                  name: api-shadow
                  namespace: shadow
                  port: 8080
                percent: 15
            - type: ExtensionRef
              extensionRef:
                group: example.net
                kind: HttpFilter
                name: authz
            - type: CORS
              cors:
                allowOrigins:
                  - https://app.example.com
                  - https://*.example.net
                allowMethods:
                  - GET
                  - POST
                allowHeaders:
                  - Authorization
                  - X-Trace-Id
                exposeHeaders:
                  - X-Response-Time
                maxAge: 86400
                allowCredentials: true
          backendRefs:
            - group: ""
              kind: Service
              name: api-svc
              namespace: backend
              port: 8080
              weight: 80
              filters:
                - type: RequestHeaderModifier
                  requestHeaderModifier:
                    add:
                      - name: x-backend
                        value: api
            - group: ""
              kind: Service
              name: api-canary
              port: 8080
              weight: 20
          timeouts:
            request: 30s
            backendRequest: 10s
          retry:
            codes:
              - 500
              - 502
            attempts: 3
            backoff: 100ms
          sessionPersistence:
            sessionName: http-session
            absoluteTimeout: 1h
            idleTimeout: 10m
            type: Cookie
            cookieConfig:
              lifetimeType: Permanent
        - name: redirect-login
          matches:
            - path:
                type: Exact
                value: /login
          filters:
            - type: RequestRedirect
              requestRedirect:
                scheme: https
                hostname: login.example.com
                path:
                  type: ReplaceFullPath
                  replaceFullPath: /signin
                port: 8443
                statusCode: 302
        - name: rewrite-v2
          matches:
            - path:
                type: PathPrefix
                value: /v2
          filters:
            - type: URLRewrite
              urlRewrite:
                hostname: internal.example.com
                path:
                  type: ReplacePrefixMatch
                  replacePrefixMatch: /internal
          backendRefs:
            - group: ""
              kind: Service
              name: internal-svc
              port: 8080
      useDefaultGateways: All

# ListenerSet example for shared listeners.
listenerSets:
  - name: shared-listeners
    namespace: apps
    labels:
      component: listener-set
    annotations:
      note: shared
    spec:
      parentRef:
        group: gateway.networking.k8s.io
        kind: Gateway
        name: edge-gateway
        namespace: edge-ns
      listeners:
        - name: shared-https
          hostname: shared.example.com
          port: 8443
          protocol: HTTPS
          tls:
            mode: Terminate
            certificateRefs:
              - group: ""
                kind: Secret
                name: shared-cert
            options:
              example.com/min-version: "1.3"
          allowedRoutes:
            namespaces:
              from: Selector
              selector:
                matchLabels:
                  tenant: shared
                matchExpressions:
                  - key: env
                    operator: In
                    values:
                      - prod
            kinds:
              - group: gateway.networking.k8s.io
                kind: HTTPRoute

# Reference grants for cross-namespace access.
referenceGrants:
  - name: allow-backend-refs
    namespace: backend
    labels:
      component: reference-grant
    annotations:
      note: cross-namespace
    spec:
      from:
        - group: gateway.networking.k8s.io
          kind: HTTPRoute
          namespace: apps
        - group: gateway.networking.k8s.io
          kind: GRPCRoute
          namespace: apps
      to:
        - group: ""
          kind: Service
          name: api-svc
        - group: ""
          kind: Secret

# TLSRoute example for SNI-based passthrough traffic.
tlsRoutes:
  - name: passthrough-tls
    namespace: apps
    labels:
      component: tls-route
    annotations:
      note: passthrough
    spec:
      parentRefs:
        - group: gateway.networking.k8s.io
          kind: Gateway
          name: edge-gateway
          namespace: edge-ns
          sectionName: tls
          port: 443
      hostnames:
        - foo.example.com
        - bar.example.com
      rules:
        - name: tls-backends
          backendRefs:
            - group: ""
              kind: Service
              name: foo-svc
              namespace: backend
              port: 443
              weight: 80
            - group: ""
              kind: Service
              name: bar-svc
              port: 8443
              weight: 20
      useDefaultGateways: All
